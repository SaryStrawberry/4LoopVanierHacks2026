import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import java.nio.charset.StandardCharsets;
import java.util.Base64;

public class Main {
    public static void main(String[] args) throws Exception {

        String teamId = "<teamId>";
        String teamAuthToken = "<teamAuthToken>";

        String auth = teamId + ":" + teamAuthToken;
        String encodedAuth = Base64.getEncoder()
                .encodeToString(auth.getBytes(StandardCharsets.US_ASCII));

        // Move JSON field into query parameter
        String verificationCode = "test-uuid";

        String url = "http://ctf26.vanierhacks.net/testingCategory/testingName"
                   + "?verificationCode=" + verificationCode;

        HttpClient client = HttpClient.newHttpClient();

        HttpRequest request = HttpRequest.newBuilder()
                .uri(URI.create(url))
                .header("Authorization", "Basic " + encodedAuth)
                .GET()
                .build();

        HttpResponse<String> response = client.send(request, HttpResponse.BodyHandlers.ofString());

        System.out.println(response.body());
    }
}